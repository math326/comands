# Kafka — endereço do cluster
KAFKA_BROKERS=192.168.1.10:9092

# Tópicos
KAFKA_TOPIC=transacoes-pix
KAFKA_DLQ_TOPIC=transacoes-pix.DLT

# Autenticação do Kafka (SASL)
KAFKA_USERNAME=producer-bancario
KAFKA_PASSWORD=coloque-a-senha-real-aqui

# Certificados SSL
SSL_KEYSTORE_PASSWORD=coloque-a-senha-do-certificado-aqui
KAFKA_TRUSTSTORE_PATH=/etc/ssl/kafka/truststore.jks
KAFKA_TRUSTSTORE_PASSWORD=coloque-a-senha-do-truststore-aqui
