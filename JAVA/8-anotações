=================================================================================================
# SPRING BOOT — estrutura									|
												|
@SpringBootApplication = classe principal — ponto de entrada do sistema inteiro			|
                         combina @Configuration + @EnableAutoConfiguration + @ComponentScan	|
												|
@RestController   = classe responde requisições HTTP e devolve JSON				|
                    combina @Controller + @ResponseBody						|
												|
@Service          = classe contém lógica de negócio						|
                    Spring gerencia o ciclo de vida dela					|
												|
@Repository       = classe acessa o banco de dados						|
                    Spring adiciona tradução de erros de banco					|
												|
@Component        = classe genérica gerenciada pelo Spring					|
                    quando não é Service nem Repository nem Controller				|
												|
@Configuration    = classe define configurações e beans do sistema				|
												|
@Bean             = método cria um objeto que o Spring vai gerenciar				|
=================================================================================================
---





=================================================================================				     # SPRING BOOT — injeção e valores						     |
										|
@Autowired        = injeta dependência automaticamente — Spring cria o objeto	|
                    pode ser no construtor, no atributo ou no método		|
										|
@Value            = injeta valor do application.properties direto na variável	|
                    @Value("${spring.kafka.bootstrap-servers}")			|
                    private String kafkaServers;				|
										|
@Qualifier        = escolhe qual implementação injetar quando tem mais de uma	|
                    @Qualifier("emailNotificador")				|
=================================================================================
---





===========================================================================
# SPRING BOOT — rotas HTTP						|
									|
@GetMapping       = método responde requisição GET			|
                    @GetMapping("/produtos")				|
									|
@PostMapping      = método responde requisição POST			|
                    @PostMapping("/produtos")				|
									|
@PutMapping       = método responde requisição PUT			|
                    @PutMapping("/produtos/{id}")			|
									|
@DeleteMapping    = método responde requisição DELETE			|
                    @DeleteMapping("/produtos/{id}")			|
									|
@PathVariable     = pega variável dentro da URL				|
                    @GetMapping("/produtos/{id}")			|
                    public Produto buscar(@PathVariable Long id)	|
									|
@RequestBody      = pega o objeto JSON do corpo da requisição		|
                    public Produto criar(@RequestBody Produto produto)	|
									|
@RequestParam     = pega parâmetro da URL				|
                    @GetMapping("/buscar")				|
                    public List<Produto> 				|
		buscar(@RequestParam String nome)			|
                    # /buscar?nome=java					|
