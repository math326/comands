

# EXISTEM 7 TIPOS DE CONSTRUTORES



# CONSTRUTOR RECEBE OBJETO
=========================================================================
# QUANDO CLASSE PRECISA DE OBJETO DE OUTRO ARQUIVO PARA FUNCIONAR:	|
									|
// Main.java								|
Scanner scanner = new Scanner(System.in);				|
Emprestimo emp  = new Emprestimo(scanner); // passa o scanner		|
									|
									|
// Emprestimo.java							|
public Emprestimo(Scanner scanner) {					|
    this.salario = scanner.nextDouble(); // usa o scanner recebido	|
}									|
									|
									|
									|
Emprestimo    emp    =    new Emprestimo   (scanner);			|
↑             ↑          ↑                 ↑				|
tipo/classe   nome        cria o objeto     passa o objeto scanner	|
              da          na memória        para dentro do construtor	|
              variável						 	|
=========================================================================





